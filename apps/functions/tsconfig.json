{
	"extends": "@suzumina.click/typescript-config/base.json",
	"compilerOptions": {
		"noEmit": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"rootDir": "./src",
		"sourceMap": true,
		"lib": ["ES2022"],
		"allowSyntheticDefaultImports": true
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts", "src/development/**/*"]
}
