{
	"name": "@suzumina.click/web",
	"version": "0.3.13",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"dev:local": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check src/ e2e/ *.ts *.mjs --files-ignore-unknown=true",
		"format": "biome format --write ./src",
		"check": "biome check --write ./src",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"typecheck:fast": "tsgo --noEmit --skipLibCheck",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:critical": "vitest run --bail 1",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:smoke": "playwright test smoke --project=chromium",
		"test:smoke:prod": "next build && PLAYWRIGHT_PROD=1 playwright test smoke --project=chromium",
		"clean": "rimraf .next coverage node_modules/.cache .vitest test-results playwright-report",
		"deploy:build": "cd ../.. && docker build -f apps/web/Dockerfile -t suzumina-web .",
		"deploy:test": "docker run --rm -p 8080:8080 suzumina-web",
		"analyze": "ANALYZE=true next build",
		"migrate:audiobuttons:dry": "tsx src/scripts/complete-audiobutton-migration.ts --dry-run",
		"migrate:audiobuttons:backup": "tsx src/scripts/complete-audiobutton-migration.ts --skip-backup --dry-run",
		"migrate:audiobuttons:run": "tsx src/scripts/complete-audiobutton-migration.ts",
		"migrate:audiobuttons:validate": "tsx src/scripts/complete-audiobutton-migration.ts --validate-only"
	},
	"dependencies": {
		"@google-cloud/firestore": "^8.6.0",
		"@hookform/resolvers": "^5.4.0",
		"@suzumina.click/shared-types": "workspace:*",
		"@suzumina.click/ui": "workspace:*",
		"better-auth": "^1.6.23",
		"lucide-react": "^1.24.0",
		"next": "^16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.81.0",
		"recharts": "3.9.2",
		"resend": "^6.17.2",
		"sonner": "^2.0.7",
		"swr": "^2.4.2",
		"web-vitals": "^5.3.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@next/bundle-analyzer": "^16.2.10",
		"@playwright/test": "^1.61.1",
		"@suzumina.click/typescript-config": "workspace:*",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"babel-plugin-react-compiler": "^1.0.0",
		"happy-dom": "^20.10.6",
		"playwright": "^1.61.1",
		"rimraf": "^6.1.3",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
