{
	"projectId": "eeb1b045-e2c8-42df-89c2-2c53101e44dc",
	"pkg": "@suzumina.click/ui",
	"globalName": "SuzuminaUI",
	"shape": "storybook",
	"storybookStatic": ".design-sync/sb-reference",
	"storybookConfigDir": "packages/ui/.storybook",
	"entry": "packages/ui/ds-entry.tsx",
	"tsconfig": "../../.design-sync/sync.tsconfig.json",
	"extraEntries": ["./ds-entry.tsx"],
	"titleMap": { "Sonner(Toast)": "Toaster" },
	"readmeHeader": ".design-sync/conventions.md",
	"overrides": {
		"Dialog": { "skip": ["ui-dialog--opens"] },
		"AlertDialog": { "skip": ["ui-alertdialog--open-interaction"] },
		"Switch": { "skip": ["ui-switch--toggle-interaction"] },
		"Toggle": { "skip": ["ui-toggle--toggles-on"] },
		"TagInput": { "skip": ["custom-form-taginput--add-tag-interaction"] },
		"AudioPlayer": {
			"cardMode": "single",
			"primaryStory": "Default",
			"skip": ["custom-audio-audioplayer--auto-play"]
		},
		"Progress": { "cardMode": "column", "skip": ["ui-progress--default"] },
		"Tabs": { "cardMode": "column", "skip": ["ui-tabs--switch-tabs-interaction"] },
		"ToggleGroup": { "cardMode": "column", "skip": ["ui-togglegroup--switch-selection"] },
		"LoadingSkeleton": { "cardMode": "column", "skip": ["custom-utility-loadingskeleton--form"] },
		"AudioButton": { "cardMode": "column" },
		"YouTubePlayer": { "cardMode": "column" },
		"ListPageLayout": { "cardMode": "column" },
		"ConfigurableList": { "cardMode": "column" },
		"Alert": { "cardMode": "column" },
		"Card": { "cardMode": "column" },
		"Carousel": { "cardMode": "column" },
		"Collapsible": { "cardMode": "column" },
		"NavigationMenu": { "cardMode": "column" },
		"Pagination": { "cardMode": "column" },
		"RadioGroup": { "cardMode": "column" },
		"Skeleton": { "cardMode": "column" },
		"Table": { "cardMode": "column" },
		"Toaster": { "cardMode": "column" },
		"NotImplementedOverlay": { "cardMode": "column" }
	},
	"buildCmd": "pnpm --filter @suzumina.click/ui exec storybook build -c .storybook -o ../../.design-sync/sb-reference"
}
