{
	"name": "suzumina.click",
	"version": "0.3.13",
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"emulator": "bash scripts/firestore-emulator.sh",
		"dev:local": "bash scripts/dev-local.sh",
		"dev:clean": "rimraf apps/web/.next && bash scripts/dev-local.sh",
		"seed": "pnpm --filter @suzumina.click/functions seed:load",
		"seed:dump": "pnpm --filter @suzumina.click/functions seed:dump",
		"lint": "pnpm -r lint",
		"lint:docs": "node scripts/lint-docs.mjs",
		"lint:tokens": "node scripts/lint-css-tokens.mjs",
		"check:index-drift": "node scripts/check-firestore-index-drift.mjs",
		"format": "pnpm -r format",
		"check": "pnpm -r check",
		"secretlint": "secretlint \"**/*\"",
		"secretlint:sarif": "secretlint --format @secretlint/secretlint-formatter-sarif --output secretlint-results.sarif \"**/*\"",
		"typecheck": "pnpm -r typecheck",
		"typecheck:fast": "pnpm -r typecheck:fast",
		"test": "pnpm -r test",
		"test:e2e:emulator": "bash scripts/e2e-emulator.sh",
		"test:integration": "bash scripts/test-functions-integration.sh",
		"verify": "pnpm lint:docs && pnpm lint:tokens && pnpm lint && pnpm typecheck && pnpm test",
		"test:coverage": "pnpm -r test:coverage",
		"knip": "knip",
		"clean": "pnpm -r clean && rimraf node_modules/.cache coverage",
		"clean:all": "pnpm clean && rimraf node_modules **/node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@secretlint/secretlint-formatter-sarif": "^13.0.2",
		"@secretlint/secretlint-rule-pattern": "^13.0.2",
		"@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
		"@typescript/native-preview": "7.0.0-dev.20260707.2",
		"@vitest/coverage-v8": "^4.1.10",
		"knip": "^6.27.0",
		"lefthook": "^2.1.10",
		"rimraf": "^6.1.3",
		"secretlint": "^13.0.2",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": "24.18.0",
		"pnpm": "11.15.1"
	},
	"packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
