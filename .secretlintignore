# secretlint がスキャンから除外するパス（.gitignore 構文）
# CI では pnpm install 後に "**/*" を走査するため、node_modules / ビルド成果物を除外する

node_modules
.next/
dist/
lib/
build/
out/
coverage/
storybook-static/
test-results/
playwright-report/
*.tsbuildinfo

# lockfile は依存メタデータのみ（シークレットを含まない）かつ巨大なため除外
pnpm-lock.yaml

# secretlint 自身の SARIF 出力
secretlint-results.sarif

# Claude Code worktrees（兄弟 worktree のソースやコピーされた .env を走査しない / ADR-008）
.claude/worktrees/
