{
	"extends": "//",
	"root": false,
	"files": {
		"maxSize": 1048576,
		"ignoreUnknown": true
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noConsole": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.stories.tsx"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": [
				"**/*.test.tsx",
				"**/*.test.ts",
				"**/test-utils/**",
				"**/chart.tsx",
				"**/vitest.setup.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"complexity": {
						"noExcessiveCognitiveComplexity": "off"
					},
					"a11y": {
						"useSemanticElements": "off"
					}
				}
			}
		}
	]
}
