{
	"name": "@suzumina.click/ui",
	"version": "0.3.13",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "echo 'UI package does not require build step' && exit 0",
		"lint": "biome check ./src --max-diagnostics=120",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"typecheck:fast": "tsgo --noEmit",
		"test": "vitest run",
		"test:storybook": "vitest run --config vitest.storybook.config.ts",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:critical": "vitest run --reporter=verbose button.test.tsx dialog.test.tsx",
		"clean": "rimraf coverage storybook-static node_modules/.cache .vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "chromatic --build-script-name=build-storybook --only-changed"
	},
	"dependencies": {
		"@suzumina.click/shared-types": "workspace:*",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel-react": "8.6.0",
		"lucide-react": "^1.21.0",
		"radix-ui": "1.6.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"peerDependencies": {
		"next": "^16.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/react-vite": "^10.4.6",
		"@suzumina.click/typescript-config": "workspace:*",
		"@tailwindcss/postcss": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"chromatic": "^17.5.0",
		"happy-dom": "^20.10.6",
		"next": "^16.2.9",
		"playwright": "^1.61.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"remark-gfm": "^4.0.1",
		"rimraf": "^6.1.3",
		"storybook": "^10.4.6",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"exports": {
		"./globals.css": "./src/styles/globals.css",
		"./postcss.config": "./postcss.config.mjs",
		"./lib/*": "./src/lib/*.ts",
		"./components/*": "./src/components/*.tsx",
		"./components/ui/*": "./src/components/ui/*.tsx",
		"./components/custom": "./src/components/custom/index.ts",
		"./components/custom/*": "./src/components/custom/*.tsx",
		"./test-utils/*": "./src/test-utils/*.ts"
	}
}
