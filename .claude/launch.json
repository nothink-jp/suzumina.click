{
	"version": "0.0.1",
	"configurations": [
		{
			"name": "storybook",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["--filter", "@suzumina.click/ui", "storybook"],
			"port": 6006,
			"autoPort": false
		},
		{
			"name": "web",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["--filter", "@suzumina.click/web", "dev"],
			"port": 3000,
			"autoPort": false
		},
		{
			"name": "web-local",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["--filter", "@suzumina.click/web", "dev:local"],
			"port": 3000,
			"autoPort": false
		},
		{
			"name": "web-prod",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["--filter", "@suzumina.click/web", "start", "--port", "3001"],
			"port": 3001,
			"autoPort": false
		}
	]
}
